BasedOnStyle: LLVM
IndentWidth: 4
UseTab: Never
BreakBeforeBraces: Custom
BraceWrapping:
  AfterFunction: false
  AfterClass: false
  AfterControlStatement: false
  AfterEnum: false
  AfterStruct: false
  AfterUnion: false
AllowShortIfStatementsOnASingleLine: true
IndentCaseLabels: true
ColumnLimit: 800
AccessModifierOffset: -4
PointerAlignment: Right
IncludeBlocks: Regroup
SortIncludes: true
IncludeCategories:
  - Regex: '^<.*>$'
    Priority: 2
  - Regex: '^".*"$'
    Priority: 1
