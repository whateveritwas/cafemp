#-------------------------------------------------------------------------------
# Linux Makefile for Café Media Player Dev
#-------------------------------------------------------------------------------

.SUFFIXES:

TOPDIR ?= $(CURDIR)

#-------------------------------------------------------------------------------
# App metadata
#-------------------------------------------------------------------------------
APP_NAME       := Café Media Player Dev
APP_SHORTNAME  := CaféMP Dev
APP_AUTHOR     := whateveritwas

#-------------------------------------------------------------------------------
# Build settings
#-------------------------------------------------------------------------------
TARGET      := cafemp
BUILD       := build

# Recursively find all source directories
SOURCES     := $(shell find src -type d)
DATA        :=

# Include source dirs as include paths
INCLUDES    := $(SOURCES)

#-------------------------------------------------------------------------------
# Compiler / linker
#-------------------------------------------------------------------------------
CC          := gcc
CXX         := g++

#-------------------------------------------------------------------------------
# Output directories
#-------------------------------------------------------------------------------
export OUTPUT := $(CURDIR)/$(TARGET)

#-------------------------------------------------------------------------------
# Source discovery
#-------------------------------------------------------------------------------
export VPATH := $(foreach dir,$(SOURCES),$(CURDIR)/$(dir)) \
                $(foreach dir,$(DATA),$(CURDIR)/$(dir))

CFILES      := $(notdir $(foreach dir,$(SOURCES),$(wildcard $(dir)/*.c)))
CPPFILES    := $(notdir $(foreach dir,$(SOURCES),$(wildcard $(dir)/*.cpp)))
SFILES      := $(notdir $(foreach dir,$(SOURCES),$(wildcard $(dir)/*.s)))

OFILES_SRC  := $(CPPFILES:.cpp=.o) $(CFILES:.c=.o) $(SFILES:.s=.o)
DEPENDS     := $(OFILES_SRC:.o=.d)

#-------------------------------------------------------------------------------
# Include paths
#-------------------------------------------------------------------------------
export INCLUDE := $(foreach dir,$(INCLUDES),-I$(CURDIR)/$(dir)) -I/usr/include/freetype2 -I/usr/include/libpng16

#-------------------------------------------------------------------------------
# Compiler flags
#-------------------------------------------------------------------------------
CFLAGS := -DDEBUG \
	  -DPLATFORM_PC \
          -Wall \
          -O0 \
          -g \
          -MMD -MP \
          $(INCLUDE)

CXXFLAGS := $(CFLAGS)

ASFLAGS := -g

#-------------------------------------------------------------------------------
# SDL2 flags
#-------------------------------------------------------------------------------
SDL_CFLAGS := $(shell sdl2-config --cflags)
SDL_LIBS   := $(shell sdl2-config --libs)

#-------------------------------------------------------------------------------
# Libraries
#-------------------------------------------------------------------------------
LIBS := $(SDL_LIBS) \
    -lSDL2_ttf \
    -lSDL2_image \
    -lmupdf \
    -lmupdf-third \
    -lharfbuzz \
    -lfreetype \
	-lpng \
-ljpeg \
-lopenjp2 \
-lwebp \
    -ljpeg \
    -lwebp \
    -lbz2 \
    -lz \
    -ljansson \
    -lswresample \
    -lavformat \
    -lavcodec \
    -lavutil \
    -lswscale \
    -lgif \
    -lm \
    -lpthread \
-lmupdf \
-lmupdf-third \
-lharfbuzz \
-lfreetype \
-lpng \
-ljpeg \
-lopenjp2 \
-ljbig2dec \
-lgumbo \
-lmujs \
-lwebp \
-lbz2 \
-lz \

#-------------------------------------------------------------------------------
# Linker flags
#-------------------------------------------------------------------------------
LDFLAGS := -g

#-------------------------------------------------------------------------------
# Build rules
#-------------------------------------------------------------------------------
.PHONY: all clean

all: $(BUILD) $(OUTPUT)

$(BUILD):
	@[ -d $@ ] || mkdir -p $@

#-------------------------------------------------------------------------------
# Link final executable
#-------------------------------------------------------------------------------
$(OUTPUT): $(addprefix $(BUILD)/,$(OFILES_SRC))
	@echo "Linking $(TARGET)..."
	$(CXX) $(LDFLAGS) -o $@ $^ $(LIBS)

#-------------------------------------------------------------------------------
# Compile C files
#-------------------------------------------------------------------------------
$(BUILD)/%.o: %.c
	@echo "Compiling C $<"
	$(CC) $(CFLAGS) $(SDL_CFLAGS) -c $< -o $@

#-------------------------------------------------------------------------------
# Compile C++ files
#-------------------------------------------------------------------------------
$(BUILD)/%.o: %.cpp
	@echo "Compiling C++ $<"
	$(CXX) $(CXXFLAGS) $(SDL_CFLAGS) -c $< -o $@

#-------------------------------------------------------------------------------
# Assemble .s files
#-------------------------------------------------------------------------------
$(BUILD)/%.o: %.s
	@echo "Assembling $<"
	$(CC) $(ASFLAGS) -c $< -o $@

#-------------------------------------------------------------------------------
# Include dependency files
#-------------------------------------------------------------------------------
-include $(addprefix $(BUILD)/,$(DEPENDS))

#-------------------------------------------------------------------------------
# Clean
#-------------------------------------------------------------------------------
clean:
	@echo "Cleaning..."
	@rm -rf $(BUILD) $(OUTPUT)

#-------------------------------------------------------------------------------
